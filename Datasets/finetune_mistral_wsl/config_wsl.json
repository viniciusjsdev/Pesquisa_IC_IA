{
  "model_info": {
    "name": "Mistral-7B-LoRA-TRL-Research-VNDatamind",
    "base_model": "mistralai/Mistral-7B-Instruct-v0.3",
    "version": "1.0.0",
    "description": "Modelo Mistral-7B fine-tuned com LoRA para análise financeira e industrial integrada usando TRL Framework e otimizações avançadas",
    "author": "VNDatamind Research",
    "date": "2025-10-26",
    "environment": "WSL Ubuntu",
    "optimization_level": "TRL-Flash-Attention-2-Optimized"
  },
  
  "paths": {
    "base_model_path": "/mnt/e/Mistral/models--mistralai--Mistral-7B-Instruct-v0.3/snapshots",
    "adapter_path": "/mnt/e/Projetos/Github_ViniciusJ/Pesquisa_IC_IA/Datasets/finetune_mistral_wsl/output",
    "data_path": "/mnt/e/Projetos/Github_ViniciusJ/Pesquisa_IC_IA/Datasets/data_ft",
    "cache_dir": "/mnt/e/Mistral",
    "output_dir": "/mnt/e/Projetos/Github_ViniciusJ/Pesquisa_IC_IA/Datasets/finetune_mistral_wsl/output"
  },
  
  "data_config": {
    "use_original_data": true,
    "no_transformation": true,
    "preserve_full_context": true,
    "max_context_length": 2048,
    "description": "Usa dados originais completos sem transformação RAG para máxima qualidade"
  },
  
  "lora_config": {
    "task_type": "CAUSAL_LM",
    "r": 8,
    "lora_alpha": 16,
    "lora_dropout": 0.1,
    "target_modules": ["q_proj", "k_proj", "v_proj", "o_proj", "gate_proj", "up_proj", "down_proj"],
    "lora_modules_to_save": ["lm_head", "embed_tokens"],
    "bias": "none",
    "inference_mode": false
  },
  
  "model_config": {
    "attn_implementation": "flash_attention_2",
    "use_liger": true,
    "torch_dtype": "bfloat16"
  },
  
  "quantization": {
    "load_in_4bit": true,
    "bnb_4bit_compute_dtype": "bfloat16",
    "bnb_4bit_use_double_quant": true,
    "bnb_4bit_quant_type": "nf4",
    "bnb_4bit_quant_storage": "bfloat16"
  },
  
  "training_config": {
    "num_train_epochs": 2,
    "per_device_train_batch_size": 1,
    "per_device_eval_batch_size": 1,
    "gradient_accumulation_steps": 18,
    "learning_rate": 1e-4,
    "weight_decay": 0.01,
    "warmup_ratio": 0.1,
    "max_seq_length": 768,
    "packing": true,
    "dataset_text_field": "text",
    "dataset_num_proc": 4,
    "fp16": false,
    "bf16": true,
    "gradient_checkpointing": true,
    "gradient_checkpointing_kwargs": {
      "use_reentrant": false
    },
    "dataloader_pin_memory": false,
    "dataloader_num_workers": 0,
    "save_steps": 100,
    "eval_steps": 100,
    "logging_steps": 10,
    "lr_scheduler_type": "constant",
    "logging_strategy": "steps",
    "save_strategy": "steps",
    "eval_strategy": "steps",
    "report_to": ["tensorboard", "wandb"],
    "logging_first_step": true,
    "max_memory": {"0": "10GB", "cpu": "22GB"}
  },
  
  "memory_optimization": {
    "max_memory": {
      "0": "10GB",
      "cpu": "22GB"
    },
    "device_map": "auto",
    "torch_dtype": "bfloat16",
    "cpu_offloading": false
  },
  
  "data_files": {
    "train": "/mnt/e/Projetos/Github_ViniciusJ/Pesquisa_IC_IA/Datasets/data_ft/train.jsonl",
    "validation": "/mnt/e/Projetos/Github_ViniciusJ/Pesquisa_IC_IA/Datasets/data_ft/val.jsonl",
    "test": "/mnt/e/Projetos/Github_ViniciusJ/Pesquisa_IC_IA/Datasets/data_ft/test.jsonl"
  },
  
  "instruction_template": {
    "format": "### Instruction:\n{instruction}\n\n### Context:\n{context}\n\n### Response:\n{response}",
    "description": "Template para fine-tuning com contexto estruturado"
  },
  
  "capabilities": {
    "financial_analysis": {
      "description": "Análise financeira de empresas",
      "examples": [
        "Análise de rentabilidade",
        "Avaliação de risco",
