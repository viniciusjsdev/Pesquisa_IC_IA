  "usage": {
    "inference_script": "python 4_inferencia_wsl.py",
    "interactive_mode": "python 4_inferencia_wsl.py --interactive",
    "examples_mode": "python 4_inferencia_wsl.py --exemplos",
    "custom_question": "python 4_inferencia_wsl.py --pergunta 'Sua pergunta' --contexto 'Contexto'"
  },
  
  "requirements": {
    "python": ">=3.8",
    "pytorch": ">=2.0.0",
    "transformers": ">=4.35.0",
    "peft": ">=0.6.0",
    "bitsandbytes": ">=0.41.0",
    "datasets": ">=2.14.0",
    "accelerate": ">=0.24.0"
  },
  
  "environment_variables": {
    "PYTORCH_CUDA_ALLOC_CONF": "expandable_segments:True",
    "CUDA_VISIBLE_DEVICES": "0",
    "TOKENIZERS_PARALLELISM": "false",
    "HF_HUB_DISABLE_TELEMETRY": "1",
