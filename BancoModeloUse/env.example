# Configurações do Sistema Integrado Financeiro-Industrial
# Copie este arquivo para .env e ajuste as configurações

# =============================================================================
# CONFIGURAÇÕES GERAIS
# =============================================================================
APP_NAME="Sistema Integrado Financeiro-Industrial"
APP_VERSION="1.0.0"
DEBUG=true
LOG_LEVEL=INFO

# =============================================================================
# CONFIGURAÇÕES DOS BANCOS DE DADOS
# =============================================================================

# Banco Financeiro (ERP/Contábil)
FINANCEIRO_DB_HOST=localhost
FINANCEIRO_DB_PORT=5432
FINANCEIRO_DB_NAME=db_financeiro
FINANCEIRO_DB_USER=postgres
FINANCEIRO_DB_PASSWORD=host
FINANCEIRO_DB_SCHEMA=financeiro

# Banco Industrial (MES/SCADA)
INDUSTRIAL_DB_HOST=localhost
INDUSTRIAL_DB_PORT=5433
INDUSTRIAL_DB_NAME=db_industrial
INDUSTRIAL_DB_USER=postgres
INDUSTRIAL_DB_PASSWORD=host
INDUSTRIAL_DB_SCHEMA=industrial

# Data Warehouse (Consolidado)
DW_DB_HOST=localhost
DW_DB_PORT=5434
DW_DB_NAME=db_datamind_dw
DW_DB_USER=postgres
DW_DB_PASSWORD=host
DW_DB_SCHEMA=dw

# =============================================================================
# CONFIGURAÇÕES ETL
# =============================================================================

# Frequência de execução ETL
ETL_DAILY_HOUR=02:00
ETL_WEEKLY_DAY=1
ETL_WEEKLY_HOUR=03:00
ETL_MONTHLY_DAY=1
ETL_MONTHLY_HOUR=04:00

# Configurações de extração
ETL_BATCH_SIZE=1000
ETL_MAX_RETRIES=3
ETL_RETRY_DELAY=300

# =============================================================================
# CONFIGURAÇÕES RAG
# =============================================================================

# Modelo local (deixe vazio para usar modelo padrão)
RAG_MODEL_PATH=""
RAG_MODEL_NAME="microsoft/DialoGPT-medium"

# Configurações do pipeline
RAG_MAX_TOKENS=512
RAG_TEMPERATURE=0.7
RAG_TOP_P=0.9

# Configurações dos agentes
RAG_AGENT_TIMEOUT=30
RAG_MAX_ITERATIONS=5

# =============================================================================
# CONFIGURAÇÕES DA API
# =============================================================================

# Servidor
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Documentação
API_DOCS_URL=/docs
API_REDOC_URL=/redoc
API_OPENAPI_URL=/openapi.json

# CORS
API_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# =============================================================================
# CONFIGURAÇÕES DE LOGGING
# =============================================================================

# Nível de log
LOG_LEVEL=INFO

# Formato de log
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"

# Arquivo de log
LOG_FILE=logs/sistema.log

# =============================================================================
# CONFIGURAÇÕES DE SEGURANÇA
# =============================================================================

# Chave secreta para JWT (gere uma nova em produção)
SECRET_KEY=your-secret-key-here

# Tempo de expiração do token (em segundos)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# CONFIGURAÇÕES DE MONITORAMENTO
# =============================================================================

# Health check
HEALTH_CHECK_INTERVAL=60

# Métricas
METRICS_ENABLED=true
METRICS_PORT=9090

# =============================================================================
# CONFIGURAÇÕES DE DESENVOLVIMENTO
# =============================================================================

# Hot reload
RELOAD=true

# Debug
DEBUG_SQL=false

# Testes
TEST_DB_NAME=test_db
TEST_DB_HOST=localhost
TEST_DB_PORT=5435

# =============================================================================
# CONFIGURAÇÕES ESPECÍFICAS DO PROJETO
# =============================================================================

# Período de dados para ETL inicial
ETL_INITIAL_START_DATE=2025-01-01
ETL_INITIAL_END_DATE=2025-01-31

# Configurações de qualidade
QUALITY_THRESHOLD=0.95
ANOMALY_DETECTION=true

# Configurações de performance
MAX_CONCURRENT_QUERIES=10
QUERY_TIMEOUT=300

# =============================================================================
# CONFIGURAÇÕES DE NOTIFICAÇÃO
# =============================================================================

# Email (opcional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Webhook (opcional)
WEBHOOK_URL=
WEBHOOK_SECRET=

# =============================================================================
# INSTRUÇÕES DE USO
# =============================================================================

# 1. Copie este arquivo para .env
# 2. Ajuste as configurações conforme seu ambiente
# 3. Configure os bancos de dados PostgreSQL
# 4. Execute: python scripts/setup_sistema.py configurar
# 5. Execute: python scripts/run_etl.py etl-inicial
# 6. Execute: python scripts/run_rag.py testar
# 7. Inicie a API: uvicorn infrastructure.api.main:app --reload
